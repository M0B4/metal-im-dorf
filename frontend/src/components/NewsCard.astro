---
import { ArrowUpRight } from "@lucide/astro";
import type { News } from "../utils/sanity";
import { formatDate } from "../utils/format";
import { buildSrcSet, urlForUncropped } from "../utils/image";
import { portableTextToPlainText } from "../utils/news";
import { sitePath } from "../utils/site";

interface Props {
  item: News;
  index: number;
  articleLabel: string;
}

const { item, index, articleLabel } = Astro.props;
const preview = portableTextToPlainText(item.inhalt);
const articleUrl = sitePath(`/news/artikel/${encodeURIComponent(item._id)}`);
---

<a class="news-tile panel" href={articleUrl} aria-label={`${item.titel} lesen`}>
  {item.bild && (
    <div class="news-media">
      <img
        src={urlForUncropped(item.bild).width(720).auto("format").quality(84).url()}
        srcset={buildSrcSet(item.bild, [240, 360, 520, 720], 82)}
        sizes="(max-width: 640px) 50vw, (max-width: 1000px) 33vw, 25vw"
        width={item.bild.width}
        height={item.bild.height}
        alt={item.bild.caption || item.bild.alt || item.titel}
        loading={index === 0 ? "eager" : "lazy"}
      />
    </div>
  )}

  <div class="news-body">
    <span class="news-date">{formatDate(item.datum)}</span>
    <h3>{item.titel}</h3>
    {preview && <p>{preview}</p>}
    <span class="news-read-more">
      {articleLabel}
      <ArrowUpRight size={17} stroke-width={2.4} aria-hidden="true" />
    </span>
  </div>
</a>

<style>
  .news-tile {
    display: grid;
    min-width: 0;
    aspect-ratio: 1 / 1.08;
    grid-template-rows: minmax(0, 55%) minmax(0, 1fr);
    overflow: hidden;
    color: inherit;
    text-decoration: none;
    transition: transform 180ms ease, border-color 180ms ease;
  }

  .news-tile:not(:has(.news-media)) {
    grid-template-rows: minmax(0, 1fr);
  }

  .news-tile:hover,
  .news-tile:focus-visible {
    border-color: color-mix(in srgb, var(--color-accent) 60%, transparent);
    outline: none;
    transform: translateY(-3px);
  }

  .news-media {
    display: flex;
    min-width: 0;
    min-height: 0;
    align-items: center;
    justify-content: center;
    padding: 0.6rem;
    overflow: hidden;
    background: #090909;
    border-bottom: 1px solid var(--border);
  }

  .news-media img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: contain;
    transition: filter 220ms ease, transform 220ms ease;
  }

  .news-tile:hover .news-media img {
    filter: contrast(1.05);
    transform: scale(1.01);
  }

  .news-body {
    display: flex;
    min-height: 0;
    flex-direction: column;
    gap: 0.55rem;
    padding: 0.9rem 1rem 1rem;
    overflow: hidden;
  }

  .news-date,
  .news-read-more {
    color: #a1a1aa;
    font-family: var(--font-mono);
    font-size: 0.66rem;
    font-weight: 800;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  h3 {
    display: -webkit-box;
    margin: 0;
    overflow: hidden;
    color: #fff;
    font-size: clamp(1.05rem, 1.7vw, 1.45rem);
    font-weight: 950;
    line-height: 1.08;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 2;
  }

  p {
    display: -webkit-box;
    margin: 0;
    overflow: hidden;
    color: #b9b9c1;
    font-size: 0.82rem;
    line-height: 1.45;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 2;
  }

  .news-read-more {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    margin-top: auto;
  }

  .news-read-more :global(svg) {
    color: var(--color-accent);
  }

  @media (max-width: 640px) {
    .news-tile {
      aspect-ratio: 1 / 1.2;
      grid-template-rows: minmax(0, 52%) minmax(0, 1fr);
    }

    .news-media {
      padding: 0.4rem;
    }

    .news-body {
      gap: 0.35rem;
      padding: 0.6rem;
    }

    .news-date,
    .news-read-more {
      font-size: 0.58rem;
      letter-spacing: 0.04em;
    }

    h3 {
      font-size: 0.9rem;
      line-height: 1.08;
    }

    p {
      display: none;
    }

    .news-read-more svg {
      width: 14px;
      height: 14px;
    }
  }
</style>
