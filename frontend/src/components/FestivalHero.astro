---
import type { Veranstaltung } from "../utils/sanity";
import type { SiteSettings } from "../utils/site";
import { formatDate } from "../utils/format";
import { sitePath } from "../utils/site";
import { buildSrcSet, urlFor } from "../utils/image";
import { getEventPath } from "../utils/events";

interface Props {
  event?: Veranstaltung;
  settings: SiteSettings;
}

const { event, settings } = Astro.props;
const hero = settings.hero;
const detailCopy = settings.sections.eventDetail;
const heroImagePath = hero.image
  ? urlFor(hero.image).width(2000).auto("format").quality(88).url()
  : sitePath("/hero-stage.jpg");
---

<section
  class:list={["hero", (!hero.showNextEvent || !event) && "hero--without-board"]}
>
  <picture class="hero-media" aria-hidden="true">
    <img
      src={heroImagePath}
      srcset={hero.image ? buildSrcSet(hero.image, [640, 960, 1440, 2000], 86) : undefined}
      sizes="(max-width: 1200px) 100vw, 1180px"
      width={hero.image?.width}
      height={hero.image?.height}
      alt=""
      fetchpriority="high"
    />
  </picture>
  <div class="hero-copy">
    <span class="section-kicker">{hero.kicker}</span>
    <h1 class="page-title">{hero.title}</h1>
    <p class="page-lede">{hero.intro}</p>
    {(hero.showPrimaryButton || hero.showSecondaryButton) && (
      <div class="hero-actions">
        {hero.showPrimaryButton && (
          <a class="metal-button" href="#news">{hero.primaryButtonLabel}</a>
        )}
        {hero.showSecondaryButton && (
          <a class="metal-button metal-button--ghost" href={sitePath("/line-up")}>
            {hero.secondaryButtonLabel}
          </a>
        )}
      </div>
    )}
  </div>

  {hero.showNextEvent && event && (
    <aside class="hero-board">
      <span>{hero.nextEventLabel}</span>
      <h2>{event.titel}</h2>
      <dl>
        <div>
          <dt>{detailCopy.dateLabel}</dt>
          <dd><time datetime={event.beginn}>{formatDate(event.beginn)}</time></dd>
        </div>
        <div>
          <dt>{detailCopy.locationLabel}</dt>
          <dd>{event.ort}</dd>
        </div>
      </dl>
      <div class="hero-board-actions">
        <a href={getEventPath(event)}>{hero.eventDetailsLabel}</a>
        {event.ticketUrl && (
          <a class="hero-ticket" href={event.ticketUrl} target="_blank" rel="noreferrer">
            {event.ticketLabel || hero.ticketFallbackLabel}
          </a>
        )}
      </div>
    </aside>
  )}
</section>

<style>
  .hero {
    position: relative;
    display: grid;
    grid-template-columns: minmax(0, 1.25fr) minmax(280px, 0.75fr);
    min-height: clamp(400px, 52vh, 540px);
    align-items: end;
    gap: 1.5rem;
    padding: clamp(1.75rem, 5vw, 3.75rem);
    overflow: hidden;
    background-color: #050505;
    border-bottom: 2px solid color-mix(in srgb, var(--color-accent) 68%, transparent);
  }

  .hero::after {
    position: absolute;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    content: "";
    background: rgba(3, 3, 3, 0.5);
  }

  .hero-media {
    position: absolute;
    inset: 0;
  }

  .hero-media img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
  }

  .hero-copy,
  .hero-board {
    position: relative;
    z-index: 1;
  }

  .hero-copy {
    max-width: 720px;
    text-shadow: 0 2px 20px rgba(0, 0, 0, 0.75);
  }

  .hero-copy :global(.section-kicker) {
    color: #f4f4f5;
  }

  .hero-copy :global(.page-lede) {
    max-width: 55ch;
    color: #e4e4e7;
  }

  .hero--without-board {
    grid-template-columns: minmax(0, 760px);
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-top: 1.6rem;
  }

  .metal-button--ghost {
    color: #fff;
    background: rgba(255, 255, 255, 0.06);
    border-color: rgba(255, 255, 255, 0.18);
  }

  .metal-button--ghost:hover {
    color: #050505;
    background: #fff;
    border-color: #fff;
  }

  .hero-board {
    padding: 1.1rem 1.2rem 1.2rem;
    background: rgba(3, 3, 3, 0.8);
    border: 1px solid rgba(255, 255, 255, 0.12);
    border-top: 2px solid var(--color-accent);
    border-radius: var(--radius-subtle);
    box-shadow: 0 12px 32px rgba(0, 0, 0, 0.24);
    text-shadow: 0 2px 12px rgba(0, 0, 0, 0.92);
  }

  @supports (backdrop-filter: blur(8px)) {
    .hero-board {
      background: rgba(3, 3, 3, 0.68);
      backdrop-filter: blur(8px) saturate(0.9);
    }
  }

  .hero-board > span,
  .hero-board dt {
    color: #f4f4f5;
    font-family: var(--font-mono);
    font-size: 0.72rem;
    font-weight: 800;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  .hero-board h2 {
    margin: 0.7rem 0 1rem;
    color: #fff;
    font-size: clamp(1.35rem, 2.7vw, 2.15rem);
    font-weight: 950;
    line-height: 1;
  }

  .hero-board dl {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1rem;
    margin: 0;
  }

  .hero-board dl div {
    min-width: 0;
  }

  .hero-board dt {
    margin-bottom: 0.25rem;
    color: var(--color-accent);
    font-size: 0.6rem;
  }

  .hero-board dd {
    margin: 0;
    color: #fff;
    font-size: 0.9rem;
    font-weight: 800;
    line-height: 1.35;
  }

  .hero-board-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.55rem;
    margin-top: 1.25rem;
  }

  .hero-board-actions a {
    padding: 0.45rem 0;
    color: #fff;
    border-bottom: 1px solid rgba(255, 255, 255, 0.55);
    font-family: var(--font-mono);
    font-size: 0.65rem;
    font-weight: 900;
    text-decoration: none;
    text-transform: uppercase;
  }

  .hero-board-actions a:hover {
    color: var(--color-accent);
    border-color: var(--color-accent);
  }

  .hero-board-actions .hero-ticket {
    padding: 0.55rem 0.75rem;
    color: var(--color-accent-contrast);
    background: var(--color-accent);
    border: 1px solid var(--color-accent);
    border-radius: var(--radius-subtle);
  }

  .hero-board-actions .hero-ticket:hover {
    filter: brightness(1.1);
  }

  @media (max-width: 860px) {
    .hero {
      grid-template-columns: 1fr;
      min-height: 520px;
      align-content: end;
    }

    .hero::after {
      background: rgba(3, 3, 3, 0.58);
    }

    .hero-board {
      display: grid;
      grid-template-columns: minmax(0, 1fr) auto;
      gap: 0.55rem 1rem;
    }

    .hero-board > span,
    .hero-board h2 {
      grid-column: 1 / -1;
    }

    .hero-board dl {
      align-self: center;
    }

    .hero-board-actions {
      align-self: end;
      justify-content: flex-end;
    }
  }

  @media (max-width: 640px) {
    .hero {
      min-height: 510px;
      padding: 1.25rem;
    }

    .hero-board {
      display: block;
    }

    .hero-board dl {
      gap: 0.7rem;
    }
  }
</style>
