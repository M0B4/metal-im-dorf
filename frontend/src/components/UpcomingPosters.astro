---
import PosterCard from "./PosterCard.astro";
import PosterGrid from "./PosterGrid.astro";
import {formatDate} from "../utils/format";
import type {Veranstaltung} from "../utils/sanity";
import type {SiteSettings} from "../utils/site";
import {getEventPath} from "../utils/events";

interface Props {
  events: Veranstaltung[];
  settings: SiteSettings;
}

const {events, settings} = Astro.props;
const copy = settings.sections.eventPosters;
const posterEvents = events.filter(
  (event): event is Veranstaltung & {bild: NonNullable<Veranstaltung["bild"]>} => Boolean(event.bild),
);
---

<section class="poster-section" aria-labelledby="poster-section-title">
  <header class="poster-heading">
    <span class="section-kicker">{copy.kicker}</span>
    <h2 id="poster-section-title">{copy.title}</h2>
  </header>

  {posterEvents.length ? (
    <PosterGrid>
      {posterEvents.map((event) => {
        const alt = event.bild.alt || `Veranstaltungsplakat ${event.titel}`;
        return (
          <PosterCard
            image={event.bild}
            alt={alt}
            eyebrow={formatDate(event.beginn)}
            title={event.titel}
            href={getEventPath(event)}
          />
        );
      })}
    </PosterGrid>
  ) : (
    <p class="placeholder">{copy.emptyText}</p>
  )}
</section>

<style>
  .poster-section {
    display: grid;
    gap: 1.25rem;
  }

  .poster-heading h2 {
    margin: 0.35rem 0 0;
    color: #fff;
    font-size: clamp(1.8rem, 4vw, 3.2rem);
    font-weight: 950;
    line-height: 1.05;
  }

</style>
