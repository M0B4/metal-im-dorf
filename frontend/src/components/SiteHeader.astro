---
import { Icon } from "astro-icon/components";
import { sitePath, type SiteSettings } from "../utils/site";
import { urlFor } from "../utils/image";

interface Props {
  currentPath: string;
  settings: SiteSettings;
}

const { currentPath, settings } = Astro.props;
const navItems = [
  { label: settings.navigation.newsLabel, path: "" },
  { label: settings.navigation.lineupLabel, path: "/line-up" },
  { label: settings.navigation.eventsLabel, path: "/veranstaltungen" },
  { label: settings.navigation.infoLabel, path: "/infos" },
  { label: settings.navigation.historyLabel, path: "/historie" },
];
const logoUrl = settings.logo
  ? urlFor(settings.logo).height(180).auto("format").quality(90).url()
  : sitePath("/logo.svg");

function isActive(path = "") {
  const target = sitePath(path).replace(/\/$/, "") || "/";
  return currentPath === target || Boolean(path && currentPath.startsWith(`${target}/`));
}
---

<header class="site-header">
  <nav class="main-nav" aria-label="Hauptnavigation">
    <div class="shell nav-inner">
      <a href={sitePath()} class="brand" aria-label={`${settings.siteName} Startseite`}>
        <img src={logoUrl} alt={settings.logo?.alt || settings.siteName} />
      </a>

      <button
        class="nav-toggle"
        id="navToggle"
        type="button"
        aria-label="Hauptmenü öffnen"
        aria-expanded="false"
        aria-controls="navMenu"
      >
        <span></span><span></span><span></span>
      </button>

      <div class="nav-links" id="navMenu">
        {navItems.map((item) => (
          <a
            href={sitePath(item.path)}
            class:list={["nav-link", isActive(item.path) && "is-active"]}
          >
            {item.label}
          </a>
        ))}
        {(settings.contact.showInstagram || settings.contact.showFacebook) && (
          <div class="header-socials" aria-label="Social Media">
          {settings.contact.showInstagram && <a
            class="social-icon"
            href={settings.contact.instagramUrl}
            target="_blank"
            rel="noreferrer"
            aria-label="Instagram"
            title="Instagram"
          >
            <Icon name="simple-icons:instagram" size={20} />
          </a>}
          {settings.contact.showFacebook && <a
            class="social-icon"
            href={settings.contact.facebookUrl}
            target="_blank"
            rel="noreferrer"
            aria-label="Facebook"
            title="Facebook"
          >
            <Icon name="simple-icons:facebook" size={20} />
          </a>}
          </div>
        )}
      </div>
    </div>
  </nav>
</header>

<script>
  const toggle = document.querySelector<HTMLButtonElement>("#navToggle");
  const menu = document.querySelector<HTMLElement>("#navMenu");

  toggle?.addEventListener("click", () => {
    const isOpen = menu?.classList.toggle("is-open") ?? false;
    toggle.classList.toggle("is-open", isOpen);
    toggle.setAttribute("aria-expanded", String(isOpen));
    toggle.setAttribute("aria-label", isOpen ? "Hauptmenü schließen" : "Hauptmenü öffnen");
  });
</script>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 40;
    background: rgba(5, 5, 5, 0.94);
    border-bottom: 1px solid rgba(255, 255, 255, 0.1);
    backdrop-filter: blur(12px);
  }

  .nav-inner {
    display: flex;
    min-height: 4.5rem;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
  }

  .brand {
    display: inline-flex;
    align-items: center;
  }

  .brand img {
    width: auto;
    height: 2.65rem;
  }

  .nav-links,
  .header-socials {
    display: flex;
    align-items: center;
  }

  .nav-links {
    gap: 0.4rem;
  }

  .nav-link {
    position: relative;
    display: inline-flex;
    min-height: 2.6rem;
    align-items: center;
    padding: 0.7rem 0.95rem;
    color: #d4d4d8;
    border: 0;
    font-family: var(--font-mono);
    font-size: 0.74rem;
    font-weight: 800;
    letter-spacing: 0.06em;
    text-decoration: none;
    text-transform: uppercase;
    transition: color 160ms ease, border-color 160ms ease, background-color 160ms ease;
  }

  .nav-link::after {
    position: absolute;
    right: 0.95rem;
    bottom: 0.35rem;
    left: 0.95rem;
    height: 2px;
    content: "";
    background: var(--color-accent);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 160ms ease;
  }

  .nav-link:hover,
  .nav-link.is-active {
    color: #fff;
  }

  .nav-link:hover::after,
  .nav-link.is-active::after {
    transform: scaleX(1);
  }

  .social-icon:hover,
  .social-icon:focus-visible {
    color: var(--color-accent);
    border-color: color-mix(in srgb, var(--color-accent) 55%, transparent);
  }

  .header-socials {
    gap: 0.4rem;
    margin-left: 0.4rem;
    padding-left: 0.8rem;
    border-left: 1px solid rgba(255, 255, 255, 0.14);
  }

  .social-icon {
    display: grid;
    width: 2.6rem;
    height: 2.6rem;
    place-items: center;
    color: #d4d4d8;
    background: transparent;
    border: 1px solid rgba(255, 255, 255, 0.14);
    border-radius: var(--radius-subtle);
    transition: color 160ms ease, background-color 160ms ease, border-color 160ms ease;
  }

  .nav-toggle {
    display: none;
    width: 2.8rem;
    height: 2.8rem;
    place-items: center;
    padding: 0.7rem;
    background: rgba(255, 255, 255, 0.06);
    border: 1px solid rgba(255, 255, 255, 0.16);
    border-radius: var(--radius-subtle);
  }

  .nav-toggle span {
    display: block;
    width: 1.25rem;
    height: 2px;
    margin: 3px 0;
    background: #fff;
    transition: transform 180ms ease, opacity 180ms ease;
  }

  .nav-toggle.is-open span:nth-child(1) { transform: translateY(5px) rotate(45deg); }
  .nav-toggle.is-open span:nth-child(2) { opacity: 0; }
  .nav-toggle.is-open span:nth-child(3) { transform: translateY(-5px) rotate(-45deg); }

  @media (max-width: 760px) {
    .nav-inner { min-height: 4.15rem; }
    .brand img { height: 2.45rem; }
    .nav-toggle { display: grid; }

    .nav-links {
      position: fixed;
      top: 4.65rem;
      right: 1rem;
      left: 1rem;
      display: none;
      flex-direction: column;
      align-items: stretch;
      padding: 0.75rem;
      background: rgba(5, 5, 5, 0.98);
      border: 1px solid rgba(255, 255, 255, 0.14);
      border-radius: var(--radius-subtle);
      box-shadow: 0 16px 40px rgba(0, 0, 0, 0.45);
    }

    @supports (backdrop-filter: blur(8px)) {
      .nav-links {
        background: rgba(5, 5, 5, 0.86);
        backdrop-filter: blur(8px) saturate(0.9);
      }
    }

    .nav-links.is-open { display: flex; }
    .nav-link { justify-content: center; min-height: 3.1rem; }

    .header-socials {
      justify-content: center;
      margin: 0.35rem 0 0;
      padding: 0.75rem 0 0;
      border-top: 1px solid rgba(255, 255, 255, 0.12);
      border-left: 0;
    }
  }
</style>
