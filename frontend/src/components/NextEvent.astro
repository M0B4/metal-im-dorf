---
import {Ticket} from "@lucide/astro";
import {getEventPath} from "../utils/events";
import {formatCompactEventDate, formatEventDay, formatEventMonthYear} from "../utils/format";
import type {Veranstaltung} from "../utils/sanity";
import type {SiteSettings} from "../utils/site";

interface Props {
  events: Veranstaltung[];
  settings: SiteSettings;
}

const {events, settings} = Astro.props;
const copy = settings.sections.nextEvent;
---

<section class="events-section" aria-labelledby="next-event-title">
  <header class="events-heading">
    <span class="section-kicker">{copy.kicker}</span>
    <h2 id="next-event-title">{copy.title}</h2>
  </header>

  {events.length ? (
    <div class="event-list">
      {events.map((event) => (
          <article class="event-row">
            <div class="event-mobile-line">
              <time datetime={event.beginn}>{formatCompactEventDate(event.beginn)}</time>
              <strong><a href={getEventPath(event)}>{event.titel}</a></strong>
              <span>{event.ort}</span>
              {event.ticketUrl && (
                <a class="mobile-ticket" href={event.ticketUrl} target="_blank" rel="noreferrer" aria-label={`Tickets für ${event.titel}`}>
                  <Ticket size={15} aria-hidden="true" />
                </a>
              )}
            </div>
            <time class="event-date" datetime={event.beginn}>
              <strong>{formatEventDay(event.beginn)}</strong>
              <span>{formatEventMonthYear(event.beginn)}</span>
            </time>
            <div class="event-copy">
              <h3><a href={getEventPath(event)}>{event.titel}</a></h3>
              {event.kurzbeschreibung && <p>{event.kurzbeschreibung}</p>}
            </div>
            <div class="event-location">
              <span>{copy.locationLabel}</span>
              <strong>{event.ort}</strong>
            </div>
            {event.ticketUrl ? (
              <a class="ticket-link" href={event.ticketUrl} target="_blank" rel="noreferrer">
                <Ticket size={16} aria-hidden="true" />
                {event.ticketLabel || "Tickets"}
              </a>
            ) : <span class="event-action-placeholder" />}
          </article>
      ))}
    </div>
  ) : (
    <p class="placeholder">{copy.emptyText}</p>
  )}
</section>

<style>
  .events-section {
    display: grid;
    gap: 0.9rem;
  }

  .events-heading h2 {
    margin: 0.35rem 0 0;
    color: #fff;
    font-size: clamp(1.5rem, 3vw, 2.35rem);
    font-weight: 950;
    line-height: 1.05;
  }

  .event-list {
    display: grid;
    border-top: 1px solid var(--border);
  }

  .event-row {
    display: grid;
    grid-template-columns: 5.25rem minmax(0, 1fr) minmax(130px, 0.4fr) auto;
    align-items: center;
    gap: clamp(1rem, 2.5vw, 1.8rem);
    padding-block: clamp(0.9rem, 2vw, 1.25rem);
    border-bottom: 1px solid var(--border);
    transition: background-color 180ms ease;
  }

  .event-row:hover {
    background: rgba(255, 255, 255, 0.025);
  }

  .event-mobile-line {
    display: none;
  }

  .event-date {
    display: grid;
    align-content: center;
    color: var(--color-accent);
    line-height: 1;
  }

  .event-date strong {
    font-size: clamp(2.1rem, 4vw, 3rem);
    font-weight: 950;
  }

  .event-date span,
  .event-location span {
    font-family: var(--font-mono);
    font-size: 0.62rem;
    font-weight: 800;
    text-transform: uppercase;
  }

  .event-date span {
    margin-top: 0.28rem;
    color: #a1a1aa;
  }

  .event-copy h3 {
    margin: 0;
    color: #fff;
    font-size: clamp(1.2rem, 2.4vw, 1.75rem);
    line-height: 1.08;
  }

  .event-copy h3 a,
  .event-mobile-line strong a {
    color: inherit;
    text-decoration: none;
  }

  .event-copy h3 a:hover,
  .event-mobile-line strong a:hover {
    color: var(--color-accent);
  }

  .ticket-link {
    display: inline-flex;
    width: fit-content;
    align-items: center;
    gap: 0.4rem;
    padding: 0.55rem 0.7rem;
    color: var(--color-accent-contrast);
    background: var(--color-accent);
    font-family: var(--font-mono);
    font-size: 0.68rem;
    font-weight: 900;
    text-decoration: none;
    text-transform: uppercase;
  }

  .event-copy p {
    max-width: 62ch;
    margin: 0.4rem 0 0;
    color: var(--muted);
    line-height: 1.55;
  }

  .event-location {
    display: grid;
    gap: 0.35rem;
  }

  .event-location span {
    color: #71717a;
  }

  .event-location strong {
    color: #e4e4e7;
    font-size: 0.9rem;
    line-height: 1.3;
  }

  @media (max-width: 900px) {
    .event-row {
      grid-template-columns: 4.75rem minmax(0, 1fr) minmax(110px, 0.35fr) auto;
      gap: 0.8rem;
    }

    .event-copy p {
      display: none;
    }
  }

  @media (max-width: 640px) {
    .event-row {
      display: block;
      padding-block: 0.7rem;
    }

    .event-copy,
    .event-date,
    .event-location,
    .ticket-link,
    .event-action-placeholder {
      display: none;
    }

    .event-mobile-line {
      display: grid;
      grid-template-columns: 3.5rem minmax(0, 1fr) minmax(0, 0.75fr) auto;
      align-items: center;
      gap: 0.55rem;
      min-width: 0;
      white-space: nowrap;
    }

    .event-mobile-line time,
    .event-mobile-line span {
      overflow: hidden;
      font-family: var(--font-mono);
      font-size: 0.64rem;
      font-weight: 800;
      text-overflow: ellipsis;
    }

    .event-mobile-line time {
      color: var(--color-accent);
    }

    .event-mobile-line strong {
      min-width: 0;
      overflow: hidden;
      color: #fff;
      font-size: 0.78rem;
      text-overflow: ellipsis;
    }

    .event-mobile-line span {
      color: var(--muted);
      text-align: right;
    }

    .mobile-ticket {
      display: grid;
      width: 2rem;
      height: 2rem;
      place-items: center;
      color: var(--color-accent-contrast);
      background: var(--color-accent);
    }
  }
</style>
