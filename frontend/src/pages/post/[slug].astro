---
import { PortableText } from "astro-portabletext";
import { createDataAttribute } from "@sanity/visual-editing-csm";
import CodeBlock from "../../components/CodeBlock.astro";
import Layout from "../../layouts/Layout.astro";
import { formatDate } from "../../utils";
import { urlFor, buildSrcSet } from "../../utils/image";
import { getPost, getPosts } from "../../utils/sanity";

export async function getStaticPaths() {
  const posts = await getPosts();
  return posts
    .filter((post) => post.slug?.current)
    .map((post) => ({ params: { slug: post.slug.current } }));
}

const { slug } = Astro.params;
const post = await getPost(slug!);

if (!post) {
  return Astro.rewrite('/404');
}

const visualEditingEnabled =
  import.meta.env.PUBLIC_SANITY_VISUAL_EDITING_ENABLED === "true";

const dataAttr = visualEditingEnabled
  ? createDataAttribute({
      projectId: import.meta.env.PUBLIC_SANITY_STUDIO_PROJECT_ID,
      dataset: import.meta.env.PUBLIC_SANITY_STUDIO_DATASET,
      baseUrl:
        import.meta.env.PUBLIC_SANITY_STUDIO_URL || "http://localhost:3333",
      id: post._id,
      type: post._type,
    })
  : null;

// SEO values: use editor-provided overrides, fall back to post fields
const seoTitle = post.seo?.metaTitle || post.title;
const seoDescription = post.seo?.metaDescription || post.excerpt;
const ogImageSource = post.seo?.ogImage ?? post.mainImage;
const ogImage = ogImageSource
  ? urlFor(ogImageSource).width(1200).height(630).fit("crop").auto("format").quality(80).url()
  : undefined;
---

<Layout
  title={seoTitle ?? "Post"}
  description={seoDescription}
  image={ogImage}
>
  <section class="max-w-4xl mx-auto space-y-6">
    <a href={base || "/"} class="inline-flex items-center gap-2 text-zinc-400 hover:text-festival-red transition duration-200 font-semibold uppercase tracking-wider text-xs">
      <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
      </svg>
      Zurück zu News
    </a>

    {
      post.mainImage ? (
        <div class="overflow-hidden rounded-2xl border border-zinc-800 shadow-[0_20px_50px_rgba(0,0,0,0.5)]">
          <img
            class="w-full h-64 md:h-96 object-cover"
            src={urlFor(post.mainImage).width(1200).height(630).fit("crop").auto("format").quality(85).url()}
            srcset={buildSrcSet(post.mainImage, [375, 750, 1200], 85)}
            sizes="(max-width: 800px) 100vw, 1200px"
            width={post.mainImage.width}
            height={post.mainImage.height}
            loading="eager"
            decoding="sync"
            alt={post.mainImage.alt || ""}
            data-sanity={dataAttr?.scope("mainImage").toString()}
          />
        </div>
      ) : null
    }

    <div class="space-y-4">
      <span class="inline-flex items-center gap-1.5 text-zinc-400 text-xs font-semibold uppercase tracking-wider">
        <svg class="h-4 w-4 text-zinc-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
        </svg>
        {formatDate(post._createdAt)}
      </span>
      <h1 class="text-3xl md:text-5xl font-black text-white uppercase tracking-wider leading-tight">{post.title}</h1>
      {post.excerpt && (
        <p class="text-lg md:text-xl font-medium text-zinc-400 leading-relaxed border-l-2 border-festival-red pl-4" data-sanity={dataAttr?.scope("excerpt").toString()}>
          {post.excerpt}
        </p>
      )}
      
      <div 
        class="prose prose-invert prose-rose max-w-none pt-6 
               prose-p:text-zinc-300 prose-p:leading-relaxed prose-p:text-base md:prose-p:text-lg
               prose-a:text-festival-red hover:prose-a:text-festival-red-hover prose-a:transition prose-a:duration-200
               prose-blockquote:border-festival-red prose-blockquote:bg-zinc-900/30 prose-blockquote:py-2 prose-blockquote:pr-4 prose-blockquote:rounded-r-lg
               prose-headings:uppercase prose-headings:tracking-wider prose-headings:font-extrabold prose-headings:text-white"
        data-sanity={dataAttr?.scope("body").toString()}
      >
        <PortableText value={post.body} components={{ type: { code: CodeBlock } }} />
      </div>
    </div>
  </section>
</Layout>
