---
import {urlForUncropped} from "../utils/image";
import type {SanityImage} from "../utils/sanity";

interface Props {
  image?: SanityImage;
  alt: string;
  eyebrow: string;
  title: string;
  href?: string;
  placeholder?: string;
  lightboxGroup?: string;
  lightboxCaption?: string;
  class?: string;
  dataCategory?: string;
}

const {
  image,
  alt,
  eyebrow,
  title,
  href,
  placeholder,
  lightboxGroup,
  lightboxCaption,
  class: className,
  dataCategory,
} = Astro.props;
const previewUrl = image
  ? urlForUncropped(image).width(720).auto("format").quality(85).url()
  : undefined;
const fullUrl = image
  ? urlForUncropped(image).width(2000).auto("format").quality(90).url()
  : undefined;
---

{href ? (
  <a href={href} class:list={["poster-card", "panel", className]} data-category={dataCategory}>
    <div class="poster-media">
      {previewUrl ? (
        <img src={previewUrl} alt={alt} loading="lazy" />
      ) : (
        <div class="poster-placeholder">{placeholder}</div>
      )}
    </div>
    <div class="poster-info">
      <span>{eyebrow}</span>
      <h2>{title}</h2>
    </div>
  </a>
) : (
  <article class:list={["poster-card", "panel", className]} data-category={dataCategory}>
    {previewUrl ? (
      <button
        type="button"
        class="poster-media poster-button"
        data-lightbox-group={lightboxGroup}
        data-full-src={fullUrl}
        data-alt={alt}
        data-caption={lightboxCaption || title}
        aria-label={`${alt} vergrößern`}
      >
        <img src={previewUrl} alt={alt} loading="lazy" />
      </button>
    ) : (
      <div class="poster-media">
        <div class="poster-placeholder">{placeholder}</div>
      </div>
    )}
    <div class="poster-info">
      <span>{eyebrow}</span>
      <h2>{title}</h2>
    </div>
  </article>
)}

<style>
  .poster-card {
    display: grid;
    grid-template-rows: auto 5.5rem;
    height: 100%;
    min-width: 0;
    overflow: hidden;
    color: inherit;
    text-decoration: none;
    transition: border-color 180ms ease, transform 180ms ease, box-shadow 180ms ease;
  }

  .poster-card[hidden] {
    display: none;
  }

  .poster-card:hover,
  .poster-card:focus-within {
    border-color: color-mix(in srgb, var(--color-accent) 50%, transparent);
    box-shadow: var(--shadow-panel);
    transform: translateY(-3px);
  }

  .poster-media {
    display: flex;
    width: 100%;
    aspect-ratio: 3 / 4;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    background: #050505;
    border: 0;
    border-bottom: 1px solid rgba(255, 255, 255, 0.12);
  }

  .poster-button {
    padding: 0;
    color: inherit;
    cursor: zoom-in;
  }

  .poster-button:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: -2px;
  }

  .poster-media img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: contain;
    transition: filter 320ms ease;
  }

  .poster-card:hover .poster-media img {
    filter: contrast(1.08);
  }

  .poster-placeholder {
    display: grid;
    width: 100%;
    height: 100%;
    place-items: center;
    color: rgba(255, 255, 255, 0.46);
    background:
      linear-gradient(135deg, rgba(255, 255, 255, 0.08), transparent 42%),
      repeating-linear-gradient(135deg, rgba(255, 255, 255, 0.06) 0 1px, transparent 1px 13px),
      #101010;
    font-family: var(--font-mono);
    font-size: 2rem;
    font-weight: 900;
  }

  .poster-info {
    display: flex;
    align-items: end;
    justify-content: space-between;
    gap: 1rem;
    padding: 1rem;
    overflow: hidden;
  }

  .poster-info span {
    color: var(--color-accent);
    font-family: var(--font-mono);
    font-size: 0.68rem;
    font-weight: 800;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .poster-info h2 {
    margin: 0;
    color: #fff;
    font-size: clamp(1.15rem, 2.5vw, 2rem);
    font-weight: 950;
    line-height: 1;
    text-align: right;
    display: -webkit-box;
    overflow: hidden;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 2;
  }

  @media (max-width: 560px) {
    .poster-card {
      grid-template-rows: auto 5.25rem;
    }

    .poster-info {
      display: grid;
      gap: 0.4rem;
      padding: 0.75rem;
    }

    .poster-info h2 {
      font-size: 1.05rem;
      text-align: left;
    }
  }
</style>
