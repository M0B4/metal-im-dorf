---
import Layout from "../../layouts/Layout.astro";
import NewsSection from "../../components/NewsSection.astro";
import { NEWS_PAGE_SIZE } from "../../utils/news";
import { getNews, getSiteSettings } from "../../utils/sanity";

export async function getStaticPaths() {
  const news = await getNews();
  const totalPages = Math.ceil(news.length / NEWS_PAGE_SIZE);

  return Array.from({ length: Math.max(0, totalPages - 1) }, (_, index) => ({
    params: { page: String(index + 2) },
  }));
}

const currentPage = Number(Astro.params.page);
const [news, settings] = await Promise.all([getNews(), getSiteSettings()]);
---

<Layout
  title={`${settings.sections.news.title} - Seite ${currentPage} | ${settings.siteName}`}
  description={settings.defaultSeo.description}
  settings={settings}
>
  <div class="shell news-page">
    <NewsSection news={news} settings={settings} currentPage={currentPage} />
  </div>
</Layout>

<style>
  .news-page {
    display: grid;
  }
</style>
