---
import Layout from "../layouts/Layout.astro";
import RunningOrder from "../components/RunningOrder.astro";
import { getCurrentLineup, getSiteSettings } from "../utils/sanity";
import { buildSrcSet, urlFor } from "../utils/image";

const [{bands, event}, settings] = await Promise.all([getCurrentLineup(), getSiteSettings()]);
const copy = settings.sections.lineup;
---

<Layout title={`${copy.title} | ${settings.siteName}`} description={copy.intro} settings={settings}>
  <div class="shell page">
    <header class="page-header">
      <span class="section-kicker">{copy.kicker}</span>
      <h1 class="page-title">{copy.title}</h1>
      <p class="page-lede">{copy.intro}</p>
      {event && <p class="lineup-event">{event.titel}</p>}
    </header>

    {copy.showRunningOrder && <RunningOrder bands={bands} copy={copy} />}

    {bands.length ? (
      <section class="band-grid" aria-label="Festival Line-Up">
        {bands.map((band, index) => (
          <article class:list={["band-card panel", band.platzhalter && "band-card--placeholder"]}>
            <div class="band-slot">{String(index + 1).padStart(2, "0")}</div>
            {band.platzhalter ? (
              <div class="band-image-wrapper band-placeholder-image">
                <span>TBA</span>
              </div>
            ) : band.bild ? (
              <div class="band-image-wrapper">
                <img
                  src={urlFor(band.bild).width(640).auto("format").quality(82).url()}
                  srcset={buildSrcSet(band.bild, [320, 480, 640, 800], 80)}
                  sizes="(max-width: 760px) 50vw, (max-width: 1180px) 33vw, 380px"
                  width={band.bild.width}
                  height={band.bild.height}
                  alt={band.name}
                  class="band-image"
                  loading="lazy"
                />
              </div>
            ) : (
              <div class="band-image-wrapper band-placeholder-image">
                <span>{band.name?.slice(0, 2) ?? "MI"}</span>
              </div>
            )}

            <div class="band-info">
              <span class:list={["genre-tag", band.platzhalter && "genre-tag--placeholder"]}>
                {band.platzhalter ? copy.placeholderGenre : band.genre || copy.defaultGenre}
              </span>
              <h2>{band.platzhalter ? copy.placeholderName : band.name}</h2>
              <p>{band.spielzeit || copy.unknownTime}</p>
            </div>
          </article>
        ))}
      </section>
    ) : (
      <p class="placeholder">{copy.emptyText}</p>
    )}
  </div>
</Layout>

<style>
  .page {
    display: grid;
    gap: clamp(2rem, 4vw, 3rem);
  }

  .page-header {
    max-width: 760px;
  }

  .lineup-event {
    width: fit-content;
    margin: 1rem 0 0;
    padding: 0.25rem 0;
    color: var(--color-accent);
    border-bottom: 1px solid color-mix(in srgb, var(--color-accent) 45%, transparent);
    font-family: var(--font-mono);
    font-size: 0.72rem;
    font-weight: 800;
  }

  .band-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1rem;
  }

  .band-card {
    position: relative;
    min-width: 0;
    overflow: hidden;
    transition: border-color 180ms ease, transform 180ms ease;
  }

  .band-card:hover {
    border-color: color-mix(in srgb, var(--color-accent) 50%, transparent);
    transform: translateY(-2px);
  }

  .band-card--placeholder {
    border-style: dashed;
  }

  .band-slot {
    position: absolute;
    top: 0.55rem;
    left: 0.55rem;
    z-index: 2;
    padding: 0.22rem 0.34rem;
    color: var(--color-accent-contrast);
    background: var(--color-accent);
    font-family: var(--font-mono);
    font-size: 0.6rem;
    font-weight: 900;
  }

  .band-image-wrapper {
    aspect-ratio: 4 / 3;
    overflow: hidden;
    background: #050505;
    border-bottom: 1px solid rgba(255, 255, 255, 0.12);
  }

  .band-image {
    width: 100%;
    height: 100%;
    display: block;
    object-fit: cover;
    filter: saturate(0.92) contrast(1.08);
    transition: transform 320ms ease, filter 320ms ease;
  }

  .band-card:hover .band-image {
    filter: saturate(1.05) contrast(1.12);
    transform: scale(1.025);
  }

  .band-placeholder-image {
    display: grid;
    place-items: center;
    background-color: #101010;
    background-image: var(--rough-texture-url);
    background-size: 512px 512px;
  }

  .band-placeholder-image span {
    color: rgba(255, 255, 255, 0.52);
    font-family: var(--font-mono);
    font-size: 2.5rem;
    font-weight: 900;
  }

  .band-info {
    display: grid;
    gap: 0.5rem;
    padding: 1rem;
  }

  .genre-tag {
    width: fit-content;
    padding: 0;
    color: #a1a1aa;
    border: 0;
    font-family: var(--font-mono);
    font-size: 0.68rem;
    font-weight: 800;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  .genre-tag--placeholder {
    color: #a1a1aa;
    border-color: rgba(255, 255, 255, 0.18);
  }

  .band-card h2 {
    margin: 0;
    color: #fff;
    font-size: clamp(1.05rem, 2vw, 1.35rem);
    font-weight: 950;
    line-height: 1.04;
  }

  .band-card p {
    margin: 0;
    color: var(--color-accent);
    font-family: var(--font-mono);
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.03em;
    text-transform: uppercase;
  }

  @media (max-width: 760px) {
    .band-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 0.75rem;
    }

    .band-info {
      padding: 0.8rem;
    }
  }
</style>
