---
import SiteFooter from "../components/SiteFooter.astro";
import SiteHeader from "../components/SiteHeader.astro";
import SiteNotice from "../components/SiteNotice.astro";
import { sitePath, type SiteSettings } from "../utils/site";
import { getSiteSettings } from "../utils/sanity";
import { urlFor } from "../utils/image";
import "../styles/global.css";
import "@fontsource-variable/inter";
import "@fontsource/ibm-plex-mono/600.css";
import "@fontsource/ibm-plex-mono/700.css";

interface Props {
  title: string;
  description?: string;
  image?: string;
  noindex?: boolean;
  settings?: SiteSettings;
  structuredData?: Record<string, unknown> | Array<Record<string, unknown>>;
}

const { title, description, image, noindex = false, settings: providedSettings, structuredData } = Astro.props;
const settings = providedSettings || (await getSiteSettings());
const canonicalURL = Astro.url;
const currentPath = canonicalURL.pathname.replace(/\/$/, "") || "/";
const visualEditingEnabled =
  import.meta.env.PUBLIC_SANITY_VISUAL_EDITING_ENABLED === "true";
const VisualEditing = visualEditingEnabled
  ? (await import("@sanity/astro/visual-editing")).VisualEditing
  : null;
const resolvedDescription = description || settings.defaultSeo.description;
const resolvedImage =
  image ||
  (settings.defaultSeo.image
    ? urlFor(settings.defaultSeo.image).width(1200).height(630).fit("crop").url()
    : undefined);
const accentColor = /^#[0-9a-f]{6}$/i.test(settings.accentColor)
  ? settings.accentColor
  : "#00A8BB";
const accentTextColor = /^#[0-9a-f]{6}$/i.test(settings.accentTextColor)
  ? settings.accentTextColor
  : "#050505";
const organizationData = {
  "@context": "https://schema.org",
  "@type": "Organization",
  name: settings.siteName,
  url: new URL(sitePath(), Astro.url.origin).href,
  email: settings.contact.email,
  sameAs: [
    settings.contact.showInstagram ? settings.contact.instagramUrl : undefined,
    settings.contact.showFacebook ? settings.contact.facebookUrl : undefined,
  ].filter(Boolean),
};
const jsonLd = JSON.stringify(
  structuredData
    ? [organizationData, ...(Array.isArray(structuredData) ? structuredData : [structuredData])]
    : organizationData,
).replace(/</g, "\\u003c");
---

<!doctype html>
<html lang="de">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/png" sizes="64x64" href={sitePath("/favicon.png")} />
    <link rel="icon" href={sitePath("/favicon.ico")} sizes="any" />
    <link rel="apple-touch-icon" sizes="180x180" href={sitePath("/apple-touch-icon.png")} />
    <meta name="generator" content={Astro.generator} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}
    <link rel="canonical" href={canonicalURL} />

    {resolvedDescription && <meta name="description" content={resolvedDescription} />}
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    {resolvedDescription && <meta property="og:description" content={resolvedDescription} />}
    {resolvedImage && <meta property="og:image" content={resolvedImage} />}
    <meta name="twitter:card" content={resolvedImage ? "summary_large_image" : "summary"} />
    <meta name="twitter:title" content={title} />
    {resolvedDescription && <meta name="twitter:description" content={resolvedDescription} />}
    {resolvedImage && <meta name="twitter:image" content={resolvedImage} />}
    <script is:inline type="application/ld+json" set:html={jsonLd}></script>

    <title>{title}</title>
  </head>
  <body
    style={`--color-accent: ${accentColor}; --color-accent-contrast: ${accentTextColor}; --rough-texture-url: url("${sitePath("/rough-texture.webp")}")`}
  >
    {VisualEditing && <VisualEditing enabled />}
    <SiteHeader currentPath={currentPath} settings={settings} />
    <SiteNotice notice={settings.notice} />
    <main class="site-main animate-slide-up"><slot /></main>
    <SiteFooter settings={settings} />
  </body>
</html>

<style>
  .site-main {
    min-height: 72vh;
    padding: clamp(1.25rem, 3vw, 2.5rem) 0 clamp(3rem, 7vw, 6rem);
  }
</style>
