---
import Layout from "../layouts/Layout.astro";
import { getHistorie } from "../utils/sanity";
import { urlFor } from "../utils/image";

const historie = await getHistorie();
---

<Layout title="Historie | Metal im Dorf" description="Die Geschichte und Rückblicke des Metal im Dorf Festivals.">
  <section class="section">
    <h1>METAL IM DORF</h1>
    <h2>Historie & Rückblick</h2>
    {historie.length ? (
      <div class="historie-grid">
        {historie.map((item, index) => (
          <div class="historie-card">
            {item.plakat && (
              <div class="poster-wrapper">
                <a
                  href="#"
                  class="poster-link"
                  data-large-src={urlFor(item.plakat).width(1200).auto("format").quality(80).url()}
                  data-caption={item.jahr}
                >
                  <img
                    src={urlFor(item.plakat).width(300).auto("format").quality(80).url()}
                    alt={`Festival Plakat ${item.jahr}`}
                    class="poster-image"
                  />
                </a>
              </div>
            )}
            <div class="jahre-info">
              <h3>{item.jahr}</h3>
            </div>
          </div>
        ))}
      </div>
      <div id="historie-lightbox" class="lightbox" hidden>
        <div class="lightbox-inner">
          <button id="historie-lightbox-close" class="lightbox-close" aria-label="Schließen">×</button>
          <img id="historie-lightbox-image" class="lightbox-image" alt="Historie Plakat" />
          <div id="historie-lightbox-caption" class="lightbox-caption"></div>
        </div>
      </div>
      <script type="module">
        const lightbox = document.getElementById('historie-lightbox');
        const lightboxImage = document.getElementById('historie-lightbox-image');
        const lightboxCaption = document.getElementById('historie-lightbox-caption');
        const closeButton = document.getElementById('historie-lightbox-close');

        document.querySelectorAll('.poster-link').forEach((link) => {
          link.addEventListener('click', (event) => {
            event.preventDefault();
            const src = link.dataset.largeSrc;
            const caption = link.dataset.caption || '';
            lightboxImage.src = src;
            lightboxImage.alt = `Festival Plakat ${caption}`;
            lightboxCaption.textContent = caption;
            lightbox.hidden = false;
          });
        });

        closeButton.addEventListener('click', () => {
          lightbox.hidden = true;
          lightboxImage.src = '';
        });

        lightbox.addEventListener('click', (event) => {
          if (!event.target.closest('.lightbox-inner')) {
            lightbox.hidden = true;
            lightboxImage.src = '';
          }
        });
      </script>
    ) : (
      <p class="placeholder">Keine Einträge in der Historie verfügbar.</p>
    )}
  </section>
</Layout>

<style>
  h1 {
    font-size: 2.5rem;
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: #fff;
    margin: 0 0 0.5rem;
    border-left: 4px solid #b91c1c;
    padding-left: 1rem;
  }

  .section {
    max-width: 1200px;
    margin: 4rem auto;
    padding: 0 1.5rem;
  }

  h2 {
    font-size: 1.5rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: #b91c1c;
    margin: 0 0 2rem;
    padding-left: 1rem;
  }

  .historie-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 2rem;
  }

  .historie-card {
    background: #111;
    border: 2px solid #222;
    overflow: hidden;
    transition: all 0.3s ease;
    cursor: pointer;
  }

  @media (max-width: 960px) {
    .historie-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 640px) {
    .historie-grid {
      grid-template-columns: 1fr;
    }
  }

  .historie-card:hover {
    border-color: #b91c1c;
    transform: translateY(-8px);
    box-shadow: 0 12px 30px rgba(185, 28, 28, 0.3);
  }

  .poster-wrapper {
    width: 100%;
    overflow: hidden;
    background: #000;
  }

  .poster-image {
    width: 100%;
    height: auto;
    object-fit: contain;
    display: block;
    transition: transform 0.3s ease;
  }

  .historie-card:hover .poster-image {
    transform: scale(1.02);
  }

  .poster-link {
    display: block;
  }

  .lightbox {
    position: fixed;
    inset: 0;
    width: 100%;
    height: 100%;
    background: rgba(0, 0, 0, 0.85);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 1rem;
    z-index: 50;
  }

  .lightbox-inner {
    position: relative;
    max-width: 90vw;
    max-height: 90vh;
    width: auto;
    padding: 1rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
    background: transparent;
  }

  .lightbox-image {
    max-width: 100%;
    max-height: 80vh;
    width: auto;
    height: auto;
    border-radius: 0.5rem;
    box-shadow: 0 20px 60px rgba(0, 0, 0, 0.45);
  }

  .lightbox-close {
    position: absolute;
    top: 1rem;
    right: 1rem;
    color: #fff;
    font-size: 2rem;
    text-decoration: none;
    line-height: 1;
    z-index: 60;
  }

  .lightbox-caption {
    color: #fff;
    font-size: 1rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .jahre-info {
    padding: 1.5rem;
    text-align: center;
  }

  .historie-card h3 {
    color: #fff;
    font-weight: 900;
    font-size: 1.8rem;
    margin: 0;
    letter-spacing: 0.05em;
  }

  .placeholder {
    color: #6b7280;
    font-style: italic;
    text-align: center;
    padding: 3rem;
    font-size: 1.2rem;
  }
</style>
