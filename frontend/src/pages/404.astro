---
import Layout from "../layouts/Layout.astro";

const base = import.meta.env.BASE_URL;
---

<Layout title="Seite nicht gefunden | Metal im Dorf">
  <section class="shell error-page">
    <span class="section-kicker">404</span>
    <h1 class="page-title">Seite nicht gefunden</h1>
    <p class="page-lede">Diese Seite existiert nicht oder wurde verschoben.</p>
    <a class="metal-button" href={base}>Zur Startseite</a>
  </section>
</Layout>

<style>
  .error-page {
    display: grid;
    justify-items: start;
    gap: 1rem;
    max-width: 820px;
  }

  .error-page .metal-button {
    margin-top: 0.75rem;
  }
</style>
