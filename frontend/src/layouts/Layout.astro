---
import { VisualEditing } from "@sanity/astro/visual-editing";
import "../styles/global.css";

interface Props {
  title: string;
  description?: string;
  image?: string;
}

const { title, description, image } = Astro.props;
const canonicalURL = Astro.url;

// Enable visual editing overlays when the env variable is set to "true"
const visualEditingEnabled =
  import.meta.env.PUBLIC_SANITY_VISUAL_EDITING_ENABLED === "true";
const base = import.meta.env.BASE_URL;
const logoPath = base && base.endsWith('/') ? base + 'logo.svg' : (base ? base + '/logo.svg' : '/logo.svg');

// Determine current request path for active nav highlighting
const currentPath = canonicalURL ? new URL(canonicalURL).pathname.replace(/\/$/, '') : "/";
function isActive(href: string) {
  try {
    const resolved = new URL(href, canonicalURL).pathname.replace(/\/$/, '');
    return currentPath === resolved;
  } catch {
    return false;
  }
}
---

<style>
  html {
    background-color: #0a0a0a;
  }
  
  body {
    background-color: #0a0a0a;
  }
</style>

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <link rel="canonical" href={canonicalURL} />

    <!-- Primary meta -->
    {description && <meta name="description" content={description} />}

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    {description && <meta property="og:description" content={description} />}
    {image && <meta property="og:image" content={image} />}

    <!-- Twitter -->
    <meta name="twitter:card" content={image ? "summary_large_image" : "summary"} />
    <meta name="twitter:title" content={title} />
    {description && <meta name="twitter:description" content={description} />}
    {image && <meta name="twitter:image" content={image} />}

    <!-- Google fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@500;700&family=Inter:wght@500;700;800&family=PT+Serif:ital,wght@0,400;0,700;1,400;1,700&display=swap"
      rel="stylesheet"
    />

    <title>{title}</title>

  </head>
  <body>
    <VisualEditing enabled={visualEditingEnabled} />
    <nav class="fixed left-0 right-0 top-0 z-10 border-b border-gray-700 bg-black">
      <div class="mx-auto sm:max-w-4xl grid grid-cols-3 items-center px-4 py-4">
        <div class="flex items-center">
          <a href={base} class="inline-block">
            <img src={logoPath} alt="Metal im Dorf" class="h-8 w-auto" />
          </a>
        </div>
        <div class="flex items-center justify-center gap-12">
          <a
            href={base || "/"}
            data-nav
            class={`${isActive(base || "/") ? 'text-[#b91c1c]' : 'text-white'} font-medium hover:text-gray-300 transition`}
          >
            News
          </a>
          <a
            href={`${base.replace(/\/$/, "")}/line-up`}
            data-nav
            class={`${isActive(`${base.replace(/\/$/, "")}/line-up`) ? 'text-[#b91c1c]' : 'text-white'} font-medium hover:text-gray-300 transition`}
          >
            Line-Up
          </a>
          <a
            href={`${base.replace(/\/$/, "")}/historie`}
            data-nav
            class={`${isActive(`${base.replace(/\/$/, "")}/historie`) ? 'text-[#b91c1c]' : 'text-white'} font-medium hover:text-gray-300 transition`}
          >
            Historie
          </a>
        </div>
        <div />
      </div>
    </nav>
    <div class="mx-auto sm:max-w-4xl">
      <main class="mt-[12px] min-h-screen pt-2 pb-[36rem] sm:pt-[1.25rem] sm:pb-[48rem]">
        <slot />
      </main>
    </div>
  </body>
  <script>
    (function(){
      try {
        const links = document.querySelectorAll('a[data-nav]');
        const path = location.pathname.replace(/\/$/, '');
        links.forEach((a) => {
          try {
            const href = new URL(a.getAttribute('href') || '/', location.origin).pathname.replace(/\/$/, '');
            if (path === href) {
              a.classList.remove('text-white');
              a.classList.add('text-[#b91c1c]');
            } else {
              a.classList.remove('text-[#b91c1c]');
              a.classList.add('text-white');
            }
          } catch (e) {}
        });
      } catch (e) {}
    })();
  </script>
</html>
