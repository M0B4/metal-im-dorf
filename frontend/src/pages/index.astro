---
import FestivalHero from "../components/FestivalHero.astro";
import NextEvent from "../components/NextEvent.astro";
import NewsSection from "../components/NewsSection.astro";
import Layout from "../layouts/Layout.astro";
import { getNews, getSiteSettings, getUpcomingEvents } from "../utils/sanity";

const [news, settings, upcomingEvents] = await Promise.all([
  getNews(),
  getSiteSettings(),
  getUpcomingEvents(),
]);
---

<Layout
  title={settings.defaultSeo.title}
  description={settings.defaultSeo.description}
  settings={settings}
>
  <div class="shell home">
    <FestivalHero featured={news[0]} settings={settings} />

    <NextEvent events={upcomingEvents} settings={settings} />

    <NewsSection news={news} settings={settings} />
  </div>
</Layout>

<style>
  .home {
    display: grid;
    gap: clamp(2rem, 5vw, 4rem);
  }

</style>
