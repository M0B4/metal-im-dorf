---
import Layout from "../../layouts/Layout.astro";
import MediaLightbox from "../../components/MediaLightbox.astro";
import { getHistorie, getSiteSettings } from "../../utils/sanity";
import { urlFor } from "../../utils/image";
import { PortableText } from "astro-portabletext";
import { ArrowLeft } from "@lucide/astro";
import { getHistoriePath, getKategorieLabel } from "../../utils/historie";
import { sitePath } from "../../utils/site";

export async function getStaticPaths() {
  const historie = await getHistorie();
  return historie.map((item) => ({
    params: { jahr: getHistoriePath(item, historie) },
    props: { item },
  }));
}

const { item } = Astro.props;
const settings = await getSiteSettings();
const copy = settings.sections.historyDetail;
const displayTitle = item.titel || `Festival ${item.jahr}`;

const lightboxGroup = `history-${item._id}`;
---

<Layout 
  title={`${displayTitle} | ${settings.siteName}`}
  description={`Rückblick und Bildergalerie: ${displayTitle}.`}
  settings={settings}
>
  <div class="shell detail-page">
    <a href={sitePath("historie")} class="back-link">
      <ArrowLeft size={17} stroke-width={2.5} aria-hidden="true" />
      {copy.backLabel}
    </a>

    <div class="detail-hero">
      {item.plakat && (
          <button
            class="detail-poster-wrapper"
            type="button"
            data-lightbox-group={lightboxGroup}
            data-full-src={urlFor(item.plakat).width(1800).auto("format").quality(88).url()}
            data-alt={`Festival Plakat ${item.jahr}`}
            data-caption={item.plakat.caption ?? item.plakat.alt ?? `Festival Plakat ${item.jahr}`}
          >
            <img 
              src={urlFor(item.plakat).width(600).auto("format").quality(85).url()} 
              alt={`Festival Plakat ${item.jahr}`} 
              class="detail-poster-image"
            />
          </button>
      )}
      
      <div class="detail-copy">
        <div>
          <span class="section-kicker">{getKategorieLabel(item.kategorie)}</span>
          <h1 class="page-title">{displayTitle}</h1>
          <p class="page-lede">{copy.introTemplate.replace("{year}", String(item.jahr))}</p>
        </div>
        
        {item.beschreibung ? (
          <div class="prose prose-invert max-w-none history-copy">
            <PortableText value={item.beschreibung} />
          </div>
        ) : (
          <p class="placeholder">{copy.emptyText}</p>
        )}
      </div>
    </div>

    {item.bilder && item.bilder.length > 0 && (
      <section class="gallery-section">
        <div class="section-heading">
          <span class="section-kicker">{copy.galleryKicker}</span>
          <h2>{copy.galleryTitle}</h2>
        </div>
        <div class="gallery-grid">
          {item.bilder.map((image, index) => {
            const imageAlt = image.caption || image.alt || `Festival Impression ${item.jahr} Bild ${index + 1}`;
            return (
              <button
                class="gallery-item-wrapper"
                type="button"
                data-lightbox-group={lightboxGroup}
                data-full-src={urlFor(image).width(1800).auto("format").quality(88).url()}
                data-alt={imageAlt}
                data-caption={image.caption ?? image.alt ?? imageAlt}
              >
                <img 
                  src={urlFor(image).width(500).auto("format").quality(80).url()} 
                  alt={imageAlt} 
                  class="gallery-image"
                  data-caption={image.caption ?? image.alt ?? ""}
                />
              </button>
            );
          })}
        </div>
      </section>
    )}

    {(item.plakat || item.bilder?.length) && <MediaLightbox />}
  </div>
</Layout>

<style>
  .detail-page {
    display: grid;
    gap: clamp(2rem, 5vw, 3.5rem);
  }

  .back-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    width: fit-content;
    color: var(--color-accent);
    font-family: var(--font-mono);
    font-size: 0.72rem;
    font-weight: 800;
    letter-spacing: 0.09em;
    text-decoration: none;
    text-transform: uppercase;
  }

  .back-link:hover {
    color: #fff;
  }

  .detail-hero {
    display: grid;
    grid-template-columns: minmax(220px, 0.72fr) minmax(0, 1.28fr);
    gap: clamp(1.25rem, 4vw, 2.5rem);
    align-items: start;
  }

  .detail-copy {
    display: grid;
    gap: 1.5rem;
    min-width: 0;
  }

  .detail-poster-wrapper {
    width: 100%;
    padding: 0;
    overflow: hidden;
    border: 1px solid rgba(255, 255, 255, 0.14);
    box-shadow: 0 20px 50px rgba(0, 0, 0, 0.5);
    background: #050505;
    cursor: zoom-in;
  }

  .detail-poster-image {
    width: 100%;
    height: auto;
    display: block;
    transition: transform 0.5s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .detail-poster-wrapper:hover .detail-poster-image {
    filter: contrast(1.05);
  }

  .prose {
    padding: clamp(1rem, 3vw, 1.5rem);
    background: var(--surface);
    border: 1px solid var(--border);
  }

  .history-copy :global(blockquote) {
    padding: 0.5rem 1rem;
    background: rgba(255, 255, 255, 0.035);
    border-left-color: var(--color-accent);
  }

  .history-copy :global(h2),
  .history-copy :global(h3) {
    color: #fff;
  }

  .gallery-section {
    display: grid;
    gap: 1.25rem;
    padding-top: 2rem;
    border-top: 1px solid rgba(255, 255, 255, 0.12);
  }

  .section-heading h2 {
    margin: 0;
    color: #fff;
    font-size: clamp(1.6rem, 3vw, 2.5rem);
    font-weight: 950;
  }

  .gallery-grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 0.75rem;
  }

  .gallery-item-wrapper {
    width: 100%;
    padding: 0;
    align-self: start;
    overflow: hidden;
    border: 1px solid rgba(255, 255, 255, 0.12);
    background: #050505;
    cursor: zoom-in;
  }

  .gallery-image {
    width: 100%;
    height: auto;
    display: block;
    object-fit: contain;
    transition: transform 0.5s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .gallery-item-wrapper:hover .gallery-image {
    filter: contrast(1.05);
  }

  @media (max-width: 1024px) {
    .gallery-grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }

  @media (max-width: 640px) {
    .gallery-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 0.5rem;
    }
  }

  @media (max-width: 768px) {
    .detail-hero {
      grid-template-columns: 1fr;
    }

    .detail-poster-wrapper {
      max-width: 420px;
    }
  }
</style>
