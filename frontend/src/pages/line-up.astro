---
import Layout from "../layouts/Layout.astro";
import { getBands } from "../utils/sanity";
import { urlFor } from "../utils/image";

const bands = await getBands();
---

<Layout title="Line-Up | Metal im Dorf" description="Das komplette Line-Up des Metal im Dorf Festivals.">
  <section class="section space-y-10">
    <div class="border-l-4 border-festival-red pl-4 py-1">
      <h1 class="text-4xl md:text-5xl font-black uppercase tracking-wider text-white">Line-Up</h1>
      <p class="text-zinc-500 mt-2 text-sm md:text-base">Erlebe die lautesten Riffs und epischsten Shows live bei uns im Dorf.</p>
    </div>

    {bands.length ? (
      <div class="band-grid">
        {bands.map((band) => (
          <div class="band-card">
            {band.bild && (
              <div class="band-image-wrapper">
                <img 
                  src={urlFor(band.bild).width(400).auto("format").quality(80).url()} 
                  alt={band.name} 
                  class="band-image" 
                />
              </div>
            )}
            <div class="band-info">
              {band.genre && <span class="genre-tag">{band.genre}</span>}
              <h3>{band.name}</h3>
              <p class="spielzeit">
                <svg class="h-3.5 w-3.5 text-zinc-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
                {band.spielzeit || "TBA"}
              </p>
            </div>
          </div>
        ))}
      </div>
    ) : (
      <p class="placeholder">Bands werden bald bekannt gegeben. 🤘</p>
    )}
  </section>
</Layout>

<style>
  .section {
    max-width: 1200px;
    margin: 0 auto;
  }

  .band-grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 1.5rem;
  }

  @media (max-width: 1024px) {
    .band-grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }

  @media (max-width: 768px) {
    .band-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 1rem;
    }
    .band-info {
      padding: 1rem;
    }
    .band-card h3 {
      font-size: 1.05rem;
    }
  }

  .band-card {
    background: rgba(23, 23, 23, 0.4);
    border: 1px solid rgba(63, 63, 70, 0.4);
    border-radius: 1rem;
    overflow: hidden;
    transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .band-card:hover {
    border-color: rgba(225, 29, 72, 0.5);
    transform: translateY(-4px);
    box-shadow: 0 12px 30px rgba(225, 29, 72, 0.1);
  }

  .band-image-wrapper {
    width: 100%;
    overflow: hidden;
    background: #09090b;
    border-bottom: 1px solid rgba(63, 63, 70, 0.3);
  }

  .band-image {
    width: 100%;
    height: auto;
    display: block;
    transition: transform 0.5s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .band-card:hover .band-image {
    transform: scale(1.05);
  }

  .band-info {
    padding: 1.25rem;
  }

  .band-card h3 {
    color: #fff;
    font-weight: 900;
    font-size: 1.2rem;
    margin: 0 0 0.5rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .genre-tag {
    color: var(--color-festival-red);
    background: rgba(225, 29, 72, 0.1);
    border: 1px solid rgba(225, 29, 72, 0.2);
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    padding: 0.15rem 0.5rem;
    border-radius: 999px;
    display: inline-block;
    margin-bottom: 0.5rem;
  }

  .spielzeit {
    color: #a1a1aa;
    font-size: 0.8rem;
    margin: 0;
    display: flex;
    align-items: center;
    gap: 0.35rem;
  }

  .placeholder {
    color: #6b7280;
    font-style: italic;
    text-align: center;
    padding: 3rem;
    font-size: 1.2rem;
  }
</style>
