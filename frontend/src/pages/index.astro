---
import FestivalHero from "../components/FestivalHero.astro";
import NewsSection from "../components/NewsSection.astro";
import Layout from "../layouts/Layout.astro";
import { getNews, getSiteSettings } from "../utils/sanity";

const [news, settings] = await Promise.all([getNews(), getSiteSettings()]);
const sortedNews = [...news].sort(
  (a, b) => new Date(b.datum || 0).getTime() - new Date(a.datum || 0).getTime(),
);
---

<Layout
  title={settings.defaultSeo.title}
  description={settings.defaultSeo.description}
  settings={settings}
>
  <div class="shell home">
    <FestivalHero featured={sortedNews[0]} settings={settings} />

    <NewsSection news={sortedNews} settings={settings} />
  </div>
</Layout>

<style>
  .home {
    display: grid;
    gap: clamp(2rem, 5vw, 4rem);
  }

</style>
