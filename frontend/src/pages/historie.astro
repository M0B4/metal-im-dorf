---
import Layout from "../layouts/Layout.astro";
import { getHistorie } from "../utils/sanity";
import { urlFor } from "../utils/image";

const historie = await getHistorie();
const base = import.meta.env.BASE_URL;
---

<Layout title="Historie | Metal im Dorf" description="Die Geschichte und Rückblicke des Metal im Dorf Festivals.">
  <section class="section space-y-10">
    <div class="border-l-4 border-festival-red pl-4 py-1">
      <h1 class="text-4xl md:text-5xl font-black uppercase tracking-wider text-white">Historie & Rückblick</h1>
      <p class="text-zinc-500 mt-2 text-sm md:text-base">Eine Zeitreise durch die vergangenen Jahre unseres legendären Festivals.</p>
    </div>

    {historie.length ? (
      <div class="historie-grid">
        {historie.map((item) => (
          <a href={`${base.replace(/\/$/, "")}/historie/${item.jahr}`} class="historie-card">
            {item.plakat && (
              <div class="poster-wrapper">
                <img
                  src={urlFor(item.plakat).width(450).auto("format").quality(80).url()}
                  alt={`Festival Plakat ${item.jahr}`}
                  class="poster-image"
                />
              </div>
            )}
            <div class="jahre-info">
              <h3>{item.jahr}</h3>
            </div>
          </a>
        ))}
      </div>
    ) : (
      <p class="placeholder">Keine Einträge in der Historie verfügbar.</p>
    )}
  </section>
</Layout>

<style>
  .section {
    max-width: 1200px;
    margin: 0 auto;
  }

  .historie-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 2rem;
  }

  .historie-card {
    background: rgba(23, 23, 23, 0.4);
    border: 1px solid rgba(63, 63, 70, 0.4);
    border-radius: 1rem;
    overflow: hidden;
    transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
    cursor: pointer;
    text-decoration: none;
    display: flex;
    flex-direction: column;
  }

  .historie-card:hover {
    border-color: rgba(225, 29, 72, 0.5);
    transform: translateY(-6px);
    box-shadow: 0 16px 36px rgba(225, 29, 72, 0.1);
  }

  @media (max-width: 960px) {
    .historie-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 640px) {
    .historie-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 1rem;
    }
    .historie-card h3 {
      font-size: 1.25rem !important;
    }
    .jahre-info {
      padding: 0.75rem !important;
    }
  }

  .poster-wrapper {
    width: 100%;
    overflow: hidden;
    background: #09090b;
    border-bottom: 1px solid rgba(63, 63, 70, 0.3);
  }

  .poster-image {
    width: 100%;
    height: auto;
    display: block;
    transition: transform 0.5s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .historie-card:hover .poster-image {
    transform: scale(1.03);
  }

  .jahre-info {
    padding: 1.25rem;
    text-align: center;
    background: rgba(15, 15, 15, 0.3);
    margin-top: auto;
  }

  .historie-card h3 {
    color: #fff;
    font-weight: 950;
    font-size: 1.5rem;
    margin: 0;
    letter-spacing: 0.05em;
  }

  .placeholder {
    color: #6b7280;
    font-style: italic;
    text-align: center;
    padding: 3rem;
    font-size: 1.2rem;
  }
</style>
