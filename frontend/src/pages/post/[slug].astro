---
import { PortableText } from "astro-portabletext";
import { createDataAttribute } from "@sanity/visual-editing-csm";
import { ArrowLeft, CalendarDays } from "@lucide/astro";
import CodeBlock from "../../components/CodeBlock.astro";
import Layout from "../../layouts/Layout.astro";
import { formatDate } from "../../utils/format";
import { urlFor, buildSrcSet } from "../../utils/image";
import { getPost, getPosts } from "../../utils/sanity";
import { sitePath } from "../../utils/site";

export async function getStaticPaths() {
  const posts = await getPosts();
  return posts
    .filter((post) => post.slug?.current)
    .map((post) => ({ params: { slug: post.slug.current } }));
}

const { slug } = Astro.params;
const post = await getPost(slug!);

if (!post) {
  return Astro.rewrite('/404');
}

const visualEditingEnabled =
  import.meta.env.PUBLIC_SANITY_VISUAL_EDITING_ENABLED === "true";

const dataAttr = visualEditingEnabled
  ? createDataAttribute({
      projectId: import.meta.env.PUBLIC_SANITY_STUDIO_PROJECT_ID,
      dataset: import.meta.env.PUBLIC_SANITY_STUDIO_DATASET,
      baseUrl:
        import.meta.env.PUBLIC_SANITY_STUDIO_URL || "http://localhost:3333",
      id: post._id,
      type: post._type,
    })
  : null;

// SEO values: use editor-provided overrides, fall back to post fields
const seoTitle = post.seo?.metaTitle || post.title;
const seoDescription = post.seo?.metaDescription || post.excerpt;
const ogImageSource = post.seo?.ogImage ?? post.mainImage;
const ogImage = ogImageSource
  ? urlFor(ogImageSource).width(1200).height(630).fit("crop").auto("format").quality(80).url()
  : undefined;
---

<Layout
  title={seoTitle ?? "Post"}
  description={seoDescription}
  image={ogImage}
>
  <article class="shell post-page">
    <a href={sitePath()} class="back-link">
      <ArrowLeft size={17} stroke-width={2.5} aria-hidden="true" />
      Zurück zu News
    </a>

    {
      post.mainImage ? (
        <div class="post-image panel">
          <img
            src={urlFor(post.mainImage).width(1400).auto("format").quality(85).url()}
            srcset={buildSrcSet(post.mainImage, [375, 750, 1200], 85)}
            sizes="(max-width: 800px) 100vw, 1200px"
            width={post.mainImage.width}
            height={post.mainImage.height}
            loading="eager"
            decoding="sync"
            alt={post.mainImage.alt || ""}
            data-sanity={dataAttr?.scope("mainImage").toString()}
          />
        </div>
      ) : null
    }

    <div class="post-content">
      <span class="post-date">
        <CalendarDays size={16} stroke-width={2.3} aria-hidden="true" />
        {formatDate(post._createdAt)}
      </span>
      <h1>{post.title}</h1>
      {post.excerpt && (
        <p class="post-excerpt" data-sanity={dataAttr?.scope("excerpt").toString()}>
          {post.excerpt}
        </p>
      )}
      
      <div 
        class="prose prose-invert max-w-none post-body"
        data-sanity={dataAttr?.scope("body").toString()}
      >
        <PortableText value={post.body} components={{ type: { code: CodeBlock } }} />
      </div>
    </div>
  </article>
</Layout>

<style>
  .post-page {
    display: grid;
    max-width: 920px;
    gap: 1.5rem;
  }

  .back-link,
  .post-date {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    width: fit-content;
    font-family: var(--font-mono);
    font-size: 0.72rem;
    font-weight: 800;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .back-link {
    color: #a1a1aa;
    text-decoration: none;
  }

  .back-link:hover,
  .post-date {
    color: var(--color-accent);
  }

  .post-image {
    overflow: hidden;
    background: #050505;
  }

  .post-image img {
    display: block;
    width: 100%;
    height: auto;
    object-fit: contain;
  }

  .post-content {
    display: grid;
    gap: 1rem;
  }

  h1 {
    margin: 0;
    color: #fff;
    font-size: clamp(2.2rem, 7vw, 4.8rem);
    font-weight: 950;
    line-height: 0.92;
  }

  .post-excerpt {
    margin: 0;
    padding-left: 1rem;
    color: #c8c8cf;
    border-left: 3px solid var(--color-accent);
    font-size: clamp(1.05rem, 2vw, 1.25rem);
    line-height: 1.65;
  }

  .post-body {
    padding-top: 1rem;
    color: #d4d4d8;
  }

  .post-body :global(a) {
    color: var(--color-accent);
  }

  .post-body :global(blockquote) {
    background: rgba(255, 255, 255, 0.035);
    border-left-color: var(--color-accent);
  }
</style>
