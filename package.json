{
  "name": "metal-im-dorf",
  "private": true,
  "description": "Website und Sanity Studio für Metal im Dorf",
  "scripts": {
    "dev": "concurrently \"npm run dev --workspace=frontend\" \"npm run dev --workspace=studio\"",
    "check": "npm run astro --workspace=frontend -- check",
    "build": "npm run build --workspace=frontend && npm run build --workspace=studio"
  },
  "keywords": ["festival", "astro", "sanity"],
  "workspaces": [
    "studio",
    "frontend"
  ],
  "engines": {
    "node": ">=22.12.0"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  },
  "type": "module"
}
