---
import Layout from "../layouts/Layout.astro";
import { getHistorie, getSiteSettings } from "../utils/sanity";
import { urlFor } from "../utils/image";
import { getHistoriePath, getKategorieLabel } from "../utils/historie";
import { sitePath } from "../utils/site";

const [historie, settings] = await Promise.all([getHistorie(), getSiteSettings()]);
const copy = settings.sections.history;
---

<Layout title={`${copy.title} | ${settings.siteName}`} description={copy.intro} settings={settings}>
  <div class="shell page">
    <header class="page-header">
      <span class="section-kicker">{copy.kicker}</span>
      <h1 class="page-title">{copy.title}</h1>
      <p class="page-lede">{copy.intro}</p>
    </header>

    {historie.length ? (
      <>
        <div class="category-filter" role="group" aria-label="Historie filtern">
          <button class="filter-button is-active" type="button" data-filter="alle">
            {copy.allFilterLabel}
          </button>
          <button class="filter-button" type="button" data-filter="hauptfestival">
            {copy.mainFilterLabel}
          </button>
          <button class="filter-button" type="button" data-filter="nebenveranstaltung">
            {copy.sideFilterLabel}
          </button>
        </div>

        <section class="history-grid" aria-label="Festival Historie">
        {historie.map((item) => (
          <a
            href={sitePath(`historie/${getHistoriePath(item, historie)}`)}
            class="history-card panel"
            data-category={item.kategorie}
          >
            <div class="poster-wrapper">
              {item.plakat ? (
                <img
                  src={urlFor(item.plakat).width(620).auto("format").quality(82).url()}
                  alt={`Festival Plakat ${item.jahr}`}
                  class="poster-image"
                  loading="lazy"
                />
              ) : (
                <div class="poster-placeholder">{item.jahr}</div>
              )}
            </div>
            <div class="year-info">
              <span>{getKategorieLabel(item.kategorie)}</span>
              <h2>{item.jahr}</h2>
            </div>
          </a>
        ))}
        </section>
        <p class="filter-empty" hidden>{copy.filterEmptyText}</p>
      </>
    ) : (
      <p class="placeholder">{copy.emptyText}</p>
    )}
  </div>
</Layout>

<style>
  .page {
    display: grid;
    gap: clamp(2rem, 4vw, 3rem);
  }

  .page-header {
    max-width: 760px;
  }

  .history-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1rem;
  }

  .category-filter {
    display: flex;
    flex-wrap: wrap;
    gap: 0.55rem;
  }

  .filter-button {
    min-height: 2.7rem;
    padding: 0.65rem 0.9rem;
    color: #d4d4d8;
    cursor: pointer;
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid rgba(255, 255, 255, 0.14);
    font-family: var(--font-mono);
    font-size: 0.7rem;
    font-weight: 900;
    letter-spacing: 0.07em;
    text-transform: uppercase;
  }

  .filter-button:hover,
  .filter-button.is-active {
    color: var(--color-accent-contrast);
    background: var(--color-accent);
    border-color: var(--color-accent);
  }

  .history-card[hidden] {
    display: none;
  }

  .history-card {
    display: grid;
    align-self: start;
    min-width: 0;
    overflow: hidden;
    color: inherit;
    text-decoration: none;
    transition: border-color 180ms ease, transform 180ms ease, box-shadow 180ms ease;
  }

  .history-card:hover {
    border-color: color-mix(in srgb, var(--color-accent) 50%, transparent);
    box-shadow: var(--shadow-panel);
    transform: translateY(-3px);
  }

  .poster-wrapper {
    overflow: hidden;
    background: #050505;
    border-bottom: 1px solid rgba(255, 255, 255, 0.12);
  }

  .poster-image {
    width: 100%;
    height: auto;
    display: block;
    object-fit: contain;
    transition: transform 320ms ease, filter 320ms ease;
  }

  .history-card:hover .poster-image {
    filter: contrast(1.08);
  }

  .poster-placeholder {
    display: grid;
    width: 100%;
    min-height: 18rem;
    place-items: center;
    color: rgba(255, 255, 255, 0.46);
    background:
      linear-gradient(135deg, rgba(255, 255, 255, 0.08), transparent 42%),
      repeating-linear-gradient(135deg, rgba(255, 255, 255, 0.06) 0 1px, transparent 1px 13px),
      #101010;
    font-family: var(--font-mono);
    font-size: 2rem;
    font-weight: 900;
  }

  .filter-empty {
    margin: 0;
    padding: 1.5rem;
    color: #a1a1aa;
    border: 1px dashed rgba(255, 255, 255, 0.16);
    text-align: center;
  }

  .year-info {
    display: flex;
    align-items: end;
    justify-content: space-between;
    gap: 1rem;
    padding: 1rem;
  }

  .year-info span {
    color: var(--color-accent);
    font-family: var(--font-mono);
    font-size: 0.68rem;
    font-weight: 800;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .year-info h2 {
    margin: 0;
    color: #fff;
    font-size: clamp(1.65rem, 4vw, 2.7rem);
    font-weight: 950;
    line-height: 0.9;
  }

  @media (max-width: 900px) {
    .history-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 560px) {
    .history-grid {
      gap: 0.75rem;
    }

    .year-info {
      display: grid;
      gap: 0.4rem;
      padding: 0.75rem;
    }
  }
</style>

<script>
  const filterButtons = document.querySelectorAll<HTMLButtonElement>(".filter-button");
  const historyCards = document.querySelectorAll<HTMLElement>(".history-card");
  const emptyState = document.querySelector<HTMLElement>(".filter-empty");

  filterButtons.forEach((button) => {
    button.addEventListener("click", () => {
      const filter = button.getAttribute("data-filter") || "alle";
      let visibleCards = 0;

      filterButtons.forEach((item) => item.classList.toggle("is-active", item === button));
      historyCards.forEach((card) => {
        const visible = filter === "alle" || card.getAttribute("data-category") === filter;
        card.toggleAttribute("hidden", !visible);
        if (visible) visibleCards += 1;
      });

      if (emptyState) emptyState.hidden = visibleCards > 0;
    });
  });
</script>
