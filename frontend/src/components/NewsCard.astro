---
import type { News, SanityImage } from "../utils/sanity";
import { formatDate } from "../utils/format";
import { urlFor } from "../utils/image";

interface Props {
  item: News;
  index: number;
}

const { item, index } = Astro.props;
const textBlocks = item.inhalt?.filter((block) => block._type === "block") ?? [];
const inlineImages = (item.inhalt?.filter((block) => block._type === "image") ?? []) as unknown as SanityImage[];
const images = [
  ...(item.bild ? [item.bild] : []),
  ...(item.bilder ?? []),
  ...inlineImages,
];
const lightboxGroup = `news-${item._id}`;
---

<article class="news-item panel">
  <div class="news-meta">
    <span>{formatDate(item.datum)}</span>
    <span>#{String(index + 1).padStart(2, "0")}</span>
  </div>

  <div class="news-layout">
    <div class="news-copy">
      <h3>{item.titel}</h3>
      {textBlocks.length > 0 && (
        <div class="news-content">
          {textBlocks.map((block) => (
            <p>{block.children?.map((child) => child.text).join("")}</p>
          ))}
        </div>
      )}
    </div>

    {images.length > 0 && (
      <div
        class:list={["news-gallery", { "news-gallery--grid": images.length > 1 }]}
        style={`--gallery-rows: ${Math.ceil(images.length / 2)}`}
      >
        {images.map((image, imageIndex) => {
          const alt = image.caption || image.alt || `${item.titel} Bild ${imageIndex + 1}`;
          return (
            <button
              class="news-gallery-item"
              type="button"
              data-lightbox-group={lightboxGroup}
              data-full-src={urlFor(image).width(1800).auto("format").quality(88).url()}
              data-alt={alt}
              data-caption={image.caption ?? image.alt ?? alt}
            >
              <img
                src={urlFor(image).width(760).auto("format").quality(82).url()}
                alt={alt}
              />
            </button>
          );
        })}
      </div>
    )}
  </div>

  <button class="news-toggle" type="button" aria-expanded="false">Mehr anzeigen</button>
</article>

<style>
  .news-item {
    --news-padding: clamp(1rem, 3vw, 1.5rem);
    padding: var(--news-padding);
    overflow: hidden;
    border-left: 4px solid var(--color-accent);
  }

  .news-item.is-collapsed .news-layout {
    position: relative;
    max-height: 18rem;
    overflow: hidden;
  }

  .news-item.is-collapsed .news-layout::after {
    position: absolute;
    right: 0;
    bottom: 0;
    left: 0;
    height: 5.5rem;
    content: "";
    pointer-events: none;
    background: linear-gradient(180deg, rgba(16, 16, 16, 0), rgba(16, 16, 16, 0.98));
  }

  .news-meta {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 1rem;
    color: var(--color-accent);
    font-family: var(--font-mono);
    font-size: 0.72rem;
    font-weight: 800;
    letter-spacing: 0.09em;
    text-transform: uppercase;
  }

  .news-layout {
    display: grid;
    grid-template-columns: minmax(0, 1.1fr) minmax(260px, 0.9fr);
    align-items: start;
    gap: 1.25rem;
  }

  .news-copy h3 {
    margin: 0 0 0.85rem;
    color: #fff;
    font-size: clamp(1.35rem, 3vw, 2.15rem);
    font-weight: 950;
    line-height: 1.02;
    text-transform: uppercase;
  }

  .news-content {
    color: #d4d4d8;
    font-size: 1rem;
    line-height: 1.75;
  }

  .news-content p {
    margin: 0 0 0.9rem;
  }

  .news-content p:last-child {
    margin-bottom: 0;
  }

  .news-gallery {
    display: grid;
    grid-template-columns: 1fr;
    min-height: 0;
    gap: 0.55rem;
  }

  .news-gallery--grid {
    grid-template-columns: repeat(2, minmax(0, 1fr));
    grid-template-rows: repeat(var(--gallery-rows), minmax(0, 1fr));
  }

  .news-gallery-item {
    display: grid;
    min-height: 0;
    place-items: center;
    padding: 0;
    overflow: hidden;
    cursor: zoom-in;
    background: transparent;
    border: 0;
  }

  .news-gallery-item img {
    display: block;
    width: 100%;
    height: 100%;
    min-height: 0;
    object-fit: contain;
    transition: filter 300ms ease;
  }

  .news-gallery-item:hover img {
    filter: contrast(1.08);
  }

  .news-toggle {
    display: none;
    width: calc(100% + (2 * var(--news-padding)));
    min-height: 3.2rem;
    justify-content: center;
    margin: 1rem calc(-1 * var(--news-padding)) calc(-1 * var(--news-padding));
    padding: 0.75rem 1rem;
    color: var(--color-accent);
    cursor: pointer;
    background: rgba(0, 168, 187, 0.06);
    border: 0;
    border-top: 1px solid rgba(0, 168, 187, 0.34);
    font-family: var(--font-mono);
    font-size: 0.72rem;
    font-weight: 900;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .news-toggle.is-visible {
    display: inline-flex;
  }

  .news-toggle:hover,
  .news-toggle:focus-visible {
    color: #050505;
    background: var(--color-accent);
  }

  @media (max-width: 860px) {
    .news-layout {
      grid-template-columns: 1fr;
    }

    .news-gallery {
      height: auto !important;
    }

    .news-gallery-item img {
      height: auto;
    }
  }

  @media (max-width: 420px) {
    .news-gallery--grid {
      grid-template-columns: 1fr;
      grid-template-rows: none;
    }
  }
</style>

<script>
  const COLLAPSE_HEIGHT = 420;
  const mobileQuery = window.matchMedia("(max-width: 860px)");

  function syncGalleryHeight(item: HTMLElement) {
    const copy = item.querySelector<HTMLElement>(".news-copy");
    const gallery = item.querySelector<HTMLElement>(".news-gallery");
    if (!copy || !gallery) return;

    if (mobileQuery.matches) {
      gallery.style.removeProperty("height");
      return;
    }

    gallery.style.height = `${copy.getBoundingClientRect().height}px`;
  }

  function setupCollapse(item: HTMLElement) {
    const layout = item.querySelector<HTMLElement>(".news-layout");
    const button = item.querySelector<HTMLButtonElement>(".news-toggle");
    if (!layout || !button) return;

    if (layout.scrollHeight <= COLLAPSE_HEIGHT) {
      item.classList.remove("is-collapsed");
      button.classList.remove("is-visible");
      return;
    }

    button.classList.add("is-visible");
    if (button.dataset.ready) return;

    button.dataset.ready = "true";
    item.classList.add("is-collapsed");
    button.addEventListener("click", () => {
      const collapsed = item.classList.toggle("is-collapsed");
      button.textContent = collapsed ? "Mehr anzeigen" : "Weniger anzeigen";
      button.setAttribute("aria-expanded", String(!collapsed));
    });
  }

  function setup(item: HTMLElement) {
    if (item.dataset.newsReady) return;
    item.dataset.newsReady = "true";

    const layout = item.querySelector<HTMLElement>(".news-layout");
    const copy = item.querySelector<HTMLElement>(".news-copy");
    syncGalleryHeight(item);
    setupCollapse(item);

    if (layout && "ResizeObserver" in window) {
      new ResizeObserver(() => setupCollapse(item)).observe(layout);
    }
    if (copy && "ResizeObserver" in window) {
      new ResizeObserver(() => syncGalleryHeight(item)).observe(copy);
    }
  }

  const newsItems = Array.from(document.querySelectorAll<HTMLElement>(".news-item"));
  newsItems.forEach(setup);
  window.addEventListener("load", () => newsItems.forEach((item) => {
    syncGalleryHeight(item);
    setupCollapse(item);
  }), { once: true });
  window.addEventListener("resize", () => newsItems.forEach(syncGalleryHeight));
</script>
