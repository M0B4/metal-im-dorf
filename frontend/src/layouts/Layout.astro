---
import SiteFooter from "../components/SiteFooter.astro";
import SiteHeader from "../components/SiteHeader.astro";
import { sitePath, type SiteSettings } from "../utils/site";
import { getSiteSettings } from "../utils/sanity";
import { urlFor } from "../utils/image";
import "../styles/global.css";

interface Props {
  title: string;
  description?: string;
  image?: string;
  noindex?: boolean;
  settings?: SiteSettings;
}

const { title, description, image, noindex = false, settings: providedSettings } = Astro.props;
const settings = providedSettings || (await getSiteSettings());
const canonicalURL = Astro.url;
const currentPath = canonicalURL.pathname.replace(/\/$/, "") || "/";
const visualEditingEnabled =
  import.meta.env.PUBLIC_SANITY_VISUAL_EDITING_ENABLED === "true";
const VisualEditing = visualEditingEnabled
  ? (await import("@sanity/astro/visual-editing")).VisualEditing
  : null;
const resolvedDescription = description || settings.defaultSeo.description;
const resolvedImage =
  image ||
  (settings.defaultSeo.image
    ? urlFor(settings.defaultSeo.image).width(1200).height(630).fit("crop").url()
    : undefined);
const accentColor = /^#[0-9a-f]{6}$/i.test(settings.accentColor)
  ? settings.accentColor
  : "#00A8BB";
const accentTextColor = /^#[0-9a-f]{6}$/i.test(settings.accentTextColor)
  ? settings.accentTextColor
  : "#050505";
---

<!doctype html>
<html lang="de">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href={sitePath("/favicon.svg")} />
    <meta name="generator" content={Astro.generator} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}
    <link rel="canonical" href={canonicalURL} />

    {resolvedDescription && <meta name="description" content={resolvedDescription} />}
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    {resolvedDescription && <meta property="og:description" content={resolvedDescription} />}
    {resolvedImage && <meta property="og:image" content={resolvedImage} />}
    <meta name="twitter:card" content={resolvedImage ? "summary_large_image" : "summary"} />
    <meta name="twitter:title" content={title} />
    {resolvedDescription && <meta name="twitter:description" content={resolvedDescription} />}
    {resolvedImage && <meta name="twitter:image" content={resolvedImage} />}

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;800;900&family=IBM+Plex+Mono:wght@600;700&display=swap"
      rel="stylesheet"
    />
    <title>{title}</title>
  </head>
  <body
    style={`--color-accent: ${accentColor}; --color-accent-contrast: ${accentTextColor}`}
  >
    {VisualEditing && <VisualEditing enabled />}
    <SiteHeader currentPath={currentPath} settings={settings} />
    <main class="site-main animate-slide-up"><slot /></main>
    <SiteFooter settings={settings} />
  </body>
</html>

<style>
  .site-main {
    min-height: 72vh;
    padding: clamp(2rem, 5vw, 4rem) 0 clamp(3rem, 7vw, 6rem);
  }
</style>
