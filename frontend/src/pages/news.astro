---
import { sitePath } from "../utils/site";

const homeUrl = sitePath();
---

<!doctype html>
<html lang="de">
  <head>
    <meta charset="utf-8" />
    <meta http-equiv="refresh" content={`0; url=${homeUrl}`} />
    <meta name="robots" content="noindex" />
    <title>Weiterleitung...</title>
  </head>
  <body>
    <p>Wenn du nicht automatisch weitergeleitet wirst, <a href={homeUrl}>klicke hier</a>.</p>
  </body>
</html>
